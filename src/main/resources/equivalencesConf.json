[
  "Adjacent tokens should be seperated by space!",
  {
    "id": 1,
    "name": "inc",
    "category": "Increment/decrement preferences",
    "codes":["$E ++ ;", "++ $E ;","$E += 1 ;","$E = $E1 + 1 ;","$E = 1 + $E1 ;"],
    "holders": ["$E","$E1"],
    "checkers": [{"class":"EqualChecker", "argsList": [[3,"$E","$E1"],[4,"$E","$E1"]]}],
    "handlers": [{"class":"ReplicationHandler","argsList":[[3, "$E","$E1"], [4, "$E","$E1"]]}]

  },
  {
    "id": 2,
    "name": "dec",
    "category": "Increment/decrement preferences",
    "codes":["$E -- ;", "-- $E ;", "$E -= 1 ;","$E = $E1 - 1 ;"],
    "holders": ["$E","$E1"],
    "checkers": [{"class":"EqualChecker", "argsList": [[3, "$E","$E1"]]}],
    "handlers": [{"class":"ReplicationHandler","argsList":[[3, "$E","$E1"]]}]

  },
  {
    "id": 26,
    "names": "assignment1",
    "category": "Assignment statement preferences",
    "codes":["$E = $E1 $HOMO_BOP $E2;", "$E $HOMO_BOP_ASSIGN $E1;"],
    "holders": ["$E", "$E1", "$E2", "$HOMO_BOP","$HOMO_BOP_ASSIGN"],
    "checkers": [
      {"class":"EqualChecker", "argsList": [[0, "$E", "$E2"]]}
    ],
    "handlers": [
      {"class":"ReplicationHandler","argsList":[[0, "$E", "$E1"]]},
      {"class":"OpOpAssignConvertHandler","argsList":[[0, 1, "$HOMO_BOP","$HOMO_BOP_ASSIGN"]]}
    ],
    "comment": "exclude <<,>>,>>>,because they are not single token(they are combinations of LT and GT).",
    "potential bug": "Overlapping with inc and dec when $E2 is 1."
  },
  {
    "id": 27,
    "names": "assignment2",
    "category": "Assignment statement preferences",
    "codes":["$E = $E1 $HOMO_BOP $E2;", "$E $HOMO_BOP_ASSIGN $E2;"],
    "holders": ["$E", "$E1", "$E2", "$HOMO_BOP","$HOMO_BOP_ASSIGN"],
    "checkers": [
      {"class":"EqualChecker", "argsList": [[0, "$E", "$E1"]]}
    ],
    "handlers": [
      {"class":"ReplicationHandler","argsList":[[0, "$E", "$E1"]]},
      {"class":"OpOpAssignConvertHandler","argsList":[[0, 1, "$HOMO_BOP","$HOMO_BOP_ASSIGN"]]}
    ],
    "comment": "exclude <<,>>,>>>,because they are not single token(they are combinations of LT and GT).",
    "potential bug": "Overlapping with inc and dec when $E2 is 1."
  },
  {
    "id": 11,
    "name": "nested if",
    "category": "Continuous logic and conditions preferences",
    "codes":[
      "if ( $E && $E1 ) $S",
      "if ( $E ) { if ( $E1 ) $S }",
      "if ( $E ) if ( $E1 ) $S "],
    "holders": ["$E", "$E1", "$S"],
    "handlers": [
      {
        "class": "WrapCondHandler",
        "argsList": [[1, 0, "$E", "$E1"], [2, 0, "$E", "$E1"]]
      }
    ]
  },
  {
    "id": 11,
    "name": "cascading if",
    "category": "Continuous logic or conditions preferences",
    "codes":[
      "if ( $E || $E1 ) $S",
      "if ( $E ) $S if ( $E1 ) $S1 "],
    "holders": ["$E", "$E1", "$S", "$S1"],
    "checkers": [
      {
        "class": "EqualChecker",
        "argsList": [[0, "$S", "$S1"]]
      }
    ],
    "handlers": [
      {"class":"ReplicationHandler","argsList":[[0, "$S", "$S1"]]}
    ]
  },
  {
    "id": 11,
    "name": "multi-branch",
    "category": "Mutlibranch",
    "codes":[
      "$S(ifElseStmt)",
      "$S(switchStmt)"
      ],
    "holders": ["$S(ifElseStmt)", "$S(switchStmt)"],
    "checkers": [
    ],
    "not implemented": "需要类型信息,if-else分支数量>=3,需要编写checker,对if-else的条件进行检查"
  },

  {
    "id": 11,
    "name": "CA",
    "category": "Continuous assignments or calls preferences",
    "codes":[
      "$E = $E1 = $E2 ;",
      "$E = $E2 ; $E1 = $E3 ;",
      "$E1 = $E2 ; $E = $E3 ;"
    ],
    "holders": ["$E", "$E1", "$E2", "$E3"],
    "checkers": [
      {
        "class": "EqualChecker",
        "argsList": [[1, "$E2", "$E3"], [2, "$E1", "$E3"]]
      }
    ],
    "handlers": [
      {"class":"ReplicationHandler","argsList": [[1, "$E2", "$E3"], [2, "$E1", "$E3"]]},
      {
        "case_handled": "从0号写法向1号写法转换，包含超过2个赋值时，例如a = b = c = d,此时最终会生成：a=d;c=d;b=d'c=d;额外生成一条c=d;语句",
        "handler_description": "实现一个handler，使用满足条件的某个子树来替换当前树。",
        "implementation_description": "当$E2是一个赋值表达式时，使用其等号左边的表达式替换$E2"
      }
    ],
    "future work": "处理两个以上的分离赋值，识别不在连续位置的分离表达式"
  },
  {
    "id": 11,
    "name": "CC",
    "category": "Continuous assignments or calls preferences",
    "codes":[
      "$E . $METHOD_CALL . $METHOD_CALL1 ;",
      "$E . $METHOD_CALL ; $E1 . $METHOD_CALL1 ;"
    ],
    "holders": ["$E", "$E1", "$METHOD_CALL", "$METHOD_CALL1"],
    "checkers": [
      {
        "class": "EqualChecker",
        "argsList": [[1, "$E", "$E1"]]
      },
      {
        "handler_description": "要求所有$METHOD_CALL都是同种函数调用，并且返回值是$E的引用"
      }
    ],
    "handlers": [
      {"class":"ReplicationHandler","argsList": [[1, "$E", "$E1"]]},
      {
        "case_handled": "从0号写法向1号写法转换，包含超过2个函数调用时，例如：e.call(1).call(2).call(3);会生成e.call(1).call(2);e.call(1).call(3)；的中间结果",
        "handler_description": "实现一个handler，使用满足条件的某个子树来替换当前树。",
        "implementation_description": "当$E1是一个函数调用表达式时，使用其dot左边的表达式替换$E1"
      }
    ],
    "future_work": "识别不在连续位置的分离调用"
  },
  {
    "id": 17,
    "name": "loop_empty",
    "category": "Loops",
    "codes":["for ( ; ; )","while ( true ) "],
    "holders": []
  },
  {
    "id": 17,
    "name": "loop1",
    "category": "Loops",
    "codes":["for ( ; $E ; )","while ( $E )"],
    "holders": ["$E_LIST", "$E_STMT","$E"]
  },
  {
    "id": 17,
    "name": "loop2",
    "category": "Loops",
    "codes":["for ( $E $(,$E)* ; $E1 ; )","$E ; $($E;)* while ( $E1 )"],
    "holders": ["$E_LIST", "$E_STMT","$E"],
    "handlers": [
      {
        "handler_description": "将表达式list修改为若干表达式语句"
      }
    ]
  },
  {
    "id": 17,
    "name": "loop3",
    "category": "Loops",
    "codes":["for ( $VAR_DEC ; $E ; )","$VAR_DEC ; while ( $E )"],
    "holders": ["$VAR_DEC", "$VAR_DEC1", "$E"],
    "handlers": [
      {
        "case_handled": "0到1转换时，根据需要修改$VAR_DEC1中的变量名以保证和当前block不存在变量名称声明冲突（虽然Java不需要考虑这种情况）"
      },
      {
        "case_handled": "1到0转换时，将for的$VAR_DEC处替换为空，"
      }
    ]
  },
  {
    "id": 17,
    "name": "loop4",
    "category": "Loops",
    "codes":[
      "for ( ; $E1 ; $E2  $(,$E)* ) { $S }",
      "while ( $E1 ) { $S $E2 ;  $($E;)* }"],
    "checker": [
      {
        "checker_description": "检查1号写法中的$E2 和 $($E;)*，他们必须对更新了表达式的值"
      }
    ]

  },
  {
    "id": 17,
    "name": "loop5",
    "category": "Loops",
    "codes":[
      "for ( $E $GROUP1(,$E)* ; $E1 ; $E2  $GROUP2(,$E)* ) { $S }",
      "$E ; $GROUP1($E;)* while ( $E1 ) { $S $E2 ;  $GROUP2($E;)* }"],
    "checker": [
      {
        "checker_description": "检查1号写法中的$E，$GROUP1($E;)*， $E2 和 $($E;)*，他们必须对更新了表达式的值"
      }
    ]
  },

  {
    "id": 17,
    "name": "loop4",
    "category": "Loops",
    "codes":[
      "for ( $VAR_DEC ; $E1 ; $E2  $GROUP(,$E)* ) { $S }",
      "$VAR_DEC while ( $E1 ) { $S $E2 ;  $GROUP($E;)* }"],
    "holders": ["$S", "$E_LIST", "$E_LIST1", "$E"],
    "checker": [
      {
        "checker_description": "检查1号写法中的$E，$GROUP1($E;)*， $E2 和 $($E;)*，他们必须对更新了表达式的值"
      }
    ],
    "handlers": [
      {
        "case_handled": "0到1转换时，根据需要修改$VAR_DEC1中的变量名以保证和当前block不存在变量名称声明冲突（虽然Java不需要考虑这种情况）"
      },
      {
        "case_handled": "1到0转换时，将for的$VAR_DEC处替换为空，"
      }
    ]
  },

  {
    "id": 10,
    "name": "check_then_return",
    "category": "Check then return preferences",
    "codes": [
      "return $E ? $E : $E1 ;",
      "$^ if ( $E ) { return $E; } return $E1;",
      "$^ if ( $E ) return $E; return $E1;",
      "if ( $E ) { return $E ; } else { return $E1 ; }",
      "if ( $E ) { return $E ; } else return $E1 ; ",
      "if ( $E ) return $E ;  else return $E1 ;",
      "if ( $E ) return $E ;  else { return $E1 ; }"
    ],
    "holders": ["$E", "$E", "$E1"]
  },
  {
    "id": 30,
    "name": "dec_then_check_assign",
    "category": "Check then assign preferences",
    "codes":[
      "$^ $M $T $I = $E ; if ( $E ) { $E1 = $E2 ; }",
      "$^ $M $T $I = $E ; if ( $E ) $E1 = $E2 ;",
      "$M $T $I = $E1 ? $E2 : $E ;",
      "$^ $M $T $I ; $E = $E1 ? $E2 : $E3 ;",
      "$^ $M $T $I ; if ( $E ) { $E1 = $E2 ; } else { $E3 = $E4 ; }",
      "$^ $M $T $I ; if ( $E ) $E1 = $E2 ; else $E3 = $E4 ;",
      "$^ $M $T $I ; if ( $E ) { $E1 = $E2 ; } else $E3 = $E4 ;",
      "$^ $M $T $I ; if ( $E ) $E1 = $E2 ; else { $E3 = $E4 ; }"
    ],
    "holders": ["$M", "$T", "$I","$I1", "$E", "$E1"],
    "checkers": [
      {"class":"EqualChecker", "argsList": [[0, "$I", "$E1"], [1, "$I", "$E1"], [3, "$I", "$E"], [4, "$I","$E1", "$E3"], [5, "$I","$E1", "$E3"], [6, "$I","$E1", "$E3"], [7, "$I","$E1", "$E3"]]}
    ],
    "handlers": [{"class":"ReplicationHandler","argsList": [[0, "$I", "$E1"], [1, "$I", "$E1"], [3, "$I", "$E"], [4, "$I","$E1", "$E3"], [5, "$I","$E1", "$E3"], [6, "$I","$E1", "$E3"], [7, "$I","$E1", "$E3"]]}]
  },
  {
    "id": 20,
    "name": "check_then_assign",
    "category": "Check then assign preferences",
    "codes":[
      "$E = $E1 ? $E2 : $E3 ;",
      "if ( $E ) { $E1 = $E2 ; } else { $E3 = $E4 ; }",
      "if ( $E ) $E1 = $E2 ; else $E3 = $E4 ;",
      "if ( $E ) { $E1 = $E2 ; } else $E3 = $E4 ;",
      "if ( $E ) $E1 = $E2 ; else { $E3 = $E4 ; }"
    ],
    "holders": ["$E","$E","$E1", "$E", "$E1"],
    "rules": ["expressionStmt", "ifElseStmt", "ifElseStmt", "ifElseStmt", "ifElseStmt"],
    "checkers": [
      {"class":"EqualChecker", "argsList": [
        [1, "$E1", "$E3"], [2, "$E1", "$E3"],[3, "$E1", "$E3"],[4, "$E1", "$E3"]
      ]}
    ],
    "handlers": [{"class":"ReplicationHandler","argsList":[
      [1, "$E1", "$E3"], [2, "$E1", "$E3"],[3, "$E1", "$E3"],[4, "$E1", "$E3"]
    ]}
    ]
  },

