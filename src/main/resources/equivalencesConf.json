[ "Adjacent tokens should be seperated by space!", {
  "id" : 1,
  "name" : "inc",
  "category" : "Increment or decrement preferences",
  "codes" : [ "$E ++ ;", "++ $E ;", "$E += 1 ;", "$E = $E1 + 1 ;", "$E = 1 + $E1 ;" ],
  "holders" : [ "$E", "$E1" ],
  "checkers" : [ {
    "class" : "EqualChecker",
    "argsList" : [ [ 3, "$E", "$E1" ], [ 4, "$E", "$E1" ] ]
  } ],
  "handlers" : [ {
    "class" : "ReplicationHandler",
    "argsList" : [ [ 3, "$E", "$E1" ], [ 4, "$E", "$E1" ] ]
  } ]
}, {
  "id" : 2,
  "name" : "dec",
  "category" : "Increment or decrement preferences",
  "codes" : [ "$E -- ;", "-- $E ;", "$E -= 1 ;", "$E = $E1 - 1 ;" ],
  "checkers" : [ {
    "class" : "EqualChecker",
    "argsList" : [ [ 3, "$E", "$E1" ] ]
  } ],
  "handlers" : [ {
    "class" : "ReplicationHandler",
    "argsList" : [ [ 3, "$E", "$E1" ] ]
  } ]
}, {
  "id" : 3,
  "names" : "assignment1",
  "category" : "Assignment statement preferences",
  "codes" : [ "$E = $E1 $HOMO_BOP $E2 ;", "$E $HOMO_BOP_ASSIGN $E2 ;" ],
  "checkers" : [ {
    "class" : "EqualChecker",
    "argsList" : [ [ 0, "$E", "$E1" ] ]
  } ,
    {
      "class": "NotIntegerChecker",
      "argsList": [[1, "$E2"]]
    }],
  "handlers" : [ {
    "class" : "ReplicationHandler",
    "argsList" : [ [ 0, "$E", "$E1" ] ]
  }, {
    "class" : "OpOpAssignConvertHandler",
    "argsList" : [ [ 0, 1, "$HOMO_BOP", "$HOMO_BOP_ASSIGN" ] ,[ 1, 0,"$HOMO_BOP_ASSIGN", "$HOMO_BOP"] ]
  } ],
  "comment" : "exclude <<,>>,>>>,because they are not single token(they are combinations of LT and GT).",
  "potential bug" : "Overlapping with inc and dec when $E2 is 1."
}, {
  "id" : 4,
  "name" : "nesting if",
  "category" : "Continuous logic and preferences",
  "codes" : [ "if ( $E && $E1 ) $S", "if ( $E ) { if ( $E1 ) $S }" ],
  "handlers" : [ {
    "class" : "WrapCondHandler",
    "argsList" : [ [ 1, 0, "$E", "$E1" ], [ 2, 0, "$E", "$E1" ] ]
  } ]
}, {
  "id" : 5,
  "name" : "cascading if",
  "category" : "Continuous logic or preferences",
  "codes" : [ "if ( $E || $E1 ) $S", "$^ if ( $E ) $S if ( $E1 ) $S1 " ],
  "checkers" : [ {
    "class" : "EqualChecker",
    "argsList" : [ [ 1, "$S", "$S1" ] ]
  } ],
  "handlers" : [ {
    "class" : "ReplicationHandler",
    "argsList" : [ [ 1, "$S", "$S1" ] ]
  } ]
}, {
  "id" : 6,
  "name" : "CA",
  "category" : "Continuous assignments or calls preferences",
  "codes" : [ "$E = $E1 = $E2 ;", "$E = $E2 ; $E1 = $E3 ;", "$E1 = $E2 ; $E = $E3 ;" ],
  "checkers" : [ {
    "class" : "EqualChecker",
    "argsList" : [ [ 1, "$E2", "$E3" ], [ 2, "$E1", "$E3" ] ]
  } ],
  "handlers" : [ {
    "class" : "ReplicationHandler",
    "argsList" : [ [ 1, "$E2", "$E3" ], [ 2, "$E1", "$E3" ] ]
  }, {
    "class" : "AssignCallExpHandler",
    "argsList" : [ [ 0, 1, "$E3" ] ]
  } ],
  "future work" : "处理两个以上的分离赋值，识别不在连续位置的分离表达式"
}, {
  "id" : 7,
  "name" : "CC",
  "category" : "Continuous assignments or calls preferences",
  "codes" : [ "$E . $METHOD_CALL . $METHOD_CALL1 ;", "$E . $METHOD_CALL ; $E1 . $METHOD_CALL1 ;" ],
  "checkers" : [ {
    "class" : "EqualChecker",
    "argsList" : [ [ 1, "$E", "$E1" ] ]
  }, {
    "handler_description" : "要求所有$METHOD_CALL都是同种函数调用，并且返回值是$E的引用"
  } ],
  "handlers" : [ {
    "class" : "ReplicationHandler",
    "argsList" : [ [ 1, "$E", "$E1" ] ]
  }, {
    "class" : "AssignCallExpHandler",
    "argsList" : [ [ 0, 1, "$E1" ] ]
  } ],
  "future_work" : "识别不在连续位置的分离调用"
}, {
  "id" : 8,
  "name" : "loop_empty",
  "category" : "Loops",
  "codes" : [ "for ( ; ; ) $S", "while ( true ) $S" ]
}, {
  "id" : 9,
  "name" : "loop1",
  "category" : "Loops",
  "codes" : [ "for ( ; $E ; ) $S", "while ( $E ) $S" ]
}, {
  "id" : 10,
  "name" : "loop2",
  "category" : "Loops",
  "codes" : [ "for ( $E_LIST ; $E1 ; ) $S", "$S(expStmt)+ while ( $E1 ) $S" ],
  "handlers" : [ {
    "class" : "Exp2ExpStmtHandler",
    "argsList" : [ [ 0, 1, "$E_LIST", "$S(expStmt)" ] ]
  }, {
    "class" : "ExpStmt2ExpHandler",
    "argsList" : [ [ 1, 0, "$S(expStmt)", "$E_LIST" ] ]
  } ]
}, {
  "id" : 11,
  "name" : "loop3",
  "category" : "Loops",
  "codes" : [ "for ( $VAR_DEC ; $E ; ) $S", "$VAR_DEC ; while ( $E ) $S" ],
  "handlers" : [ {
    "case_handled" : "0到1转换时，根据需要修改$VAR_DEC1中的变量名以保证和当前block不存在变量名称声明冲突（虽然Java不需要考虑这种情况）"
  }, {
    "case_handled" : "1到0转换时，将for的$VAR_DEC处替换为空，"
  } ]
}, {
  "id" : 12,
  "name" : "loop4",
  "category" : "Loops",
  "codes" : [ "for ( ; $E1 ; $EXP_LIST ) { $S }", "while ( $E1 ) { $S $S(expStmt)+ }" ],
  "checker" : [ {
    "checker_description" : "检查1号写法中的$S(expStmt)+，他们必须对更新了表达式的值"
  } ]
}, {
  "id" : 13,
  "name" : "loop5",
  "category" : "Loops",
  "codes" : [ "for ( $EXP_LIST ; $E1 ; $EXP_LIST1 ) { $S }", "$S(expStmt)+ while ( $E1 ) { $S $S1(expStmt)+ }" ],
  "checker" : [ {
    "checker_description" : "检查1号写法中的$S(expStmt)+,$S1(expStmt)+，他们必须对更新了表达式的值"
  } ]
}, {
  "id" : 14,
  "name" : "loop4",
  "category" : "Loops",
  "codes" : [ "for ( $VAR_DEC ; $E1 ; $EXP_LIST ) { $S }", "$VAR_DEC ; while ( $E1 ) { $S $S(expStmt)+ }" ],
  "checker" : [ {
    "checker_description" : "检查1号写法中的$S(expStmt)+，他们必须对更新了表达式的值"
  } ],
  "handlers" : [ {
    "case_handled" : "0到1转换时，根据需要修改$VAR_DEC1中的变量名以保证和当前block不存在变量名称声明冲突（虽然Java不需要考虑这种情况）"
  }, {
    "case_handled" : "1到0转换时，将for的$VAR_DEC处替换为空，"
  } ]
}, {
  "id" : 15,
  "name" : "check_then_return",
  "category" : "Check then return preferences",
  "codes" : [ "return $E ? $E1 : $E2 ;", "if ( $E ) { return $E1 ; } else { return $E2 ; }" ]
}, {
  "id" : 16,
  "name" : "dec_then_check_assign",
  "category" : "Check then assign preferences",
  "codes" : [ "$^ $M $T $I = $E2 ; if ( $E ) { $E3 = $E1 ; }", "$M $T $I = $E ? $E1 : $E2 ;", "$^ $M $T $I ; $E3 = $E ? $E1 : $E2 ;", "$^ $M $T $I ; if ( $E ) { $E3 = $E1 ; } else { $E4 = $E2 ; }" ],
  "checkers" : [ {
    "class" : "EqualChecker",
    "argsList" : [ [ 0, "$I", "$E3" ], [ 2, "$I", "$E3" ], [ 3, "$I", "$E3", "$E4" ] ]
  } ],
  "handlers" : [ {
    "class" : "ReplicationHandler",
    "argsList" : [ [ 0, "$I", "$E3" ], [ 2, "$I", "$E3" ], [ 3, "$I", "$E3", "$E4" ] ]
  } ]
}, {
  "id" : 17,
  "name" : "check_then_assign",
  "category" : "Check then assign preferences",
  "codes" : [ "$E = $E1 ? $E2 : $E3 ;", "if ( $E1 ) { $E = $E2 ; } else { $E4 = $E3 ; }" ],
  "checkers" : [ {
    "class" : "EqualChecker",
    "argsList" : [ [ 1, "$E", "$E4" ] ]
  } ],
  "handlers" : [ {
    "class" : "ReplicationHandler",
    "argsList" : [ [ 1, "$E", "$E4" ] ]
  } ]
}, {
  "id" : 18,
  "category" : "Operator preferences",
  "codes" : [ "$E < $E1", "$E1 > $E" ],
  "checkers" : [
  ],
  "handlers" : [ ]
}, {
  "id" : 19,
  "category" : "Operator preferences",
  "codes" : [ "$E <= $E1", "$E1 >= $E" ],
  "checkers" : [ ],
  "handlers" : [ ]
}, {
  "id" : 20,
  "category" : "Operator preferences",
  "codes" : [ "$E == false", "! $E" ],
  "checkers" : [ ],
  "handlers" : [ ]
}, {
  "id" : 22,
  "category" : "Literal position in bool expression",
  "codes" : [ "$LITERAL == $E", "$E == $LITERAL" ],
  "checkers" : [ ],
  "handlers" : [ ]
}, {
  "id" : 23,
  "name" : "return_tmp_var",
  "category" : "Return statements",
  "codes" : [ "$^ $M $T $I = $E ; return $E1 ;", "return $E ;" ],
  "checkers" : [ {
    "class" : "EqualChecker",
    "argsList" : [ [ 0, "$I", "$E1" ] ]
  }, {
    "class" : "NotIdentifierExpChecker",
    "argsList" : [ [ 1, "$E" ] ]
  } ],
  "handlers" : [ {
    "handler_description" : "为$M $T $I对应的终端节点设置文本值"
  } ]
}, {
  "id" : 24,
  "name" : "return_with_paren",
  "category" : "Return statements",
  "codes" : [ "return ( $E ) ;", "return $E ;" ]
}, {
  "id" : 25,
  "category" : "Array declaration style",
  "codes" : [ "$M $T [] $I ;", "$M $T $I [] ;" ]
},  {
  "id" : 27,
  "category" : "Array declaration style",
  "codes" : [ "$M $T [] $I = $ARRAY_INITIALIZER ;", "$M $T $I [] = $ARRAY_INITIALIZER ;" ]
},   {
  "id" : 30,
  "category" : "Continue preferences",
  "codes" : [ "$^ if ( $E ) { continue ; }  $S+", "if ( $E ) { continue ; } else { $S+ }","if ( $E ) { $S+ }" ],
  "checkers" : [ {
    "class" : "ContinuePreferenceChecker",
    "argsList" : [ [ 0, "$S+" ] ,[ 1, "$E" ],[ 2, "$E" ]]
  } ],
  "handlers" : [ {
    "class" : "CondReverserHandler",
    "argsList" : [ [ 0, 1, "$E" ] ]
  } ]
}, {
  "id" : 31,
  "category" : "Continue preferences",
  "codes" : [ "$^ if ( $E ) { $S+ continue ; }  $S1+", "if ( $E ) { $S+ continue ; } else { $S1+ }","if ( $E ) { $S+ } else { $S1+ }" ],
  "checkers" : [ {
    "class" : "ContinuePreferenceChecker",
    "argsList" : [ [ 0, "$S1+" ] ,[ 1, "$E" ],[ 2, "$E" ]]
  },{
    "class" : "NoStmtChecker",
    "argsList" : [ [2, "continueStmt", "$S+"]]
  }  ]
}, {
  "id" : 32,
  "category" : "Redundant code",
  "codes" : [ "$^ if ( $E ) { $S+ }  $S1+", "if ( $E ) { $S+ } else { $S1+  }" ],
  "checkers" : [ {
    "class" : "NoStmtChecker",
    "argsList" : [ [ 0, "continueStmt", "breakStmt", "returnStmt", "$S+" ] ]
  }, {
    "class": "EndsWithChecker",
    "argsList": [[1, "$S+", "$S1+"]]
  } ],
  "handlers" : [ {
    "class" : "AppendTreeHandler",
    "argsList" : [ [0, 1, "$S+", "$S1+" ] ]
  } ],
  "comments": "Consider to add complexity checker to check the complexity of '$S1+'"
}
]