<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="line_statement">
    <rule>
      <style_context maxTextLength="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <style_context type1="DECLARATION_STMT" type2="DECLARATION_STMT" minCodeBockLines="0" hasSameDecType="true"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="CONDITIONAL_STMT" type2="DECLARATION_STMT" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="CONDITIONAL_STMT" type2="EXPRESSION_STMT" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="CONDITIONAL_STMT" minCodeBockLines="125"/>
      <style_property newlines="2"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="CONDITIONAL_STMT" minCodeBockLines="67"/>
      <style_property newlines="2"/>
    </rule>
    <rule>
      <style_context type1="importDeclarationList" type2="TYPE_DEC" minCodeBockLines="0"/>
      <style_property newlines="2"/>
    </rule>
    <rule>
      <style_context type1="EXPRESSION_STMT" type2="SINGLE_STMT" minCodeBockLines="0"/>
      <style_property newlines="0"/>
    </rule>
  </style>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" "/>
    </rule>
  </style>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>MULTI_BLOCK_STMT_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="false"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
  </style>
  <style name="declaration_location">
    <rule>
      <style_property>
        <avgLineDis2firstUse>5.2</avgLineDis2firstUse>
        <location>BLOCK_START</location>
      </style_property>
    </rule>
  </style>
  <style name="lineWrapping">
    <rule>
      <style_context/>
      <style_property/>
    </rule>
    <rule>
      <style_context/>
      <style_property/>
    </rule>
  </style>
  <style name="space">
    <rule>
      <style_context token="IDENTIFIER, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, LITERAL"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="[, ]"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=",, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="BIN_OP"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="}, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="(, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="), ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ["/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, ("/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="DOT"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="], IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
  </style>
  <style name="body_layout"/>
</program_style>
