<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format">
    <rule>
      <style_context name_type="TYPE"/>
      <style_property case_format="UPPER_CAMEL" start_with_underscore="false" max_length="6"/>
    </rule>
    <rule>
      <style_context name_type="METHOD"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="4"/>
    </rule>
    <rule>
      <style_context name_type="LOCAL_VARIABLE"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="7"/>
    </rule>
  </style>
  <style name="if_else_body_order"/>
  <style name="indention">
    <rule>
      <style_property indentionUnit="1" indentionType="\t"/>
    </rule>
  </style>
  <style name="optional_brace"/>
  <style name="multi_branch"/>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="true"/>
    </rule>
  </style>
  <style name="declaration_layout">
    <rule>
      <style_context has_comment="false"/>
      <style_property variable_count="5" max_length="45"/>
    </rule>
  </style>
  <style name="most_complex_expression">
    <rule>
      <style_context expType="TOP_EXP"/>
      <style_property maxExpressionLength="23" maxSubExpNum="4"/>
    </rule>
  </style>
  <style name="lineWrapping">
    <rule>
      <style_context attr="COMMENT"/>
      <style_property variance="0.0" maxLen="0" maxLenBefore="0" succeedLoc="0">
        <breakLoc reg=" +|[,.]" after="true"/>
      </style_property>
    </rule>
    <rule>
      <style_context attr="CODE"/>
      <style_property variance="0.0" maxLen="0" maxLenBefore="0" succeedLoc="0">
        <breakLoc reg="," after="true"/>
        <breakLoc reg="[?:]" after="true"/>
        <breakLoc reg="[.]" after="false"/>
        <breakLoc reg="[&amp;]{2}" after="true"/>
        <breakLoc reg="[|]{2}" after="true"/>
        <breakLoc reg="[-+*/%&amp;|^]" after="true"/>
        <breakLoc reg="[=]{2,3}" after="true"/>
        <breakLoc reg="[-+*/%&amp;|^]=|&lt;&lt;=|&gt;&gt;=|&gt;&gt;&gt;=" after="true"/>
        <breakLoc reg="&lt;|&lt;=|&gt;|&gt;=|==|!=" after="true"/>
        <breakLoc reg="[(]" after="true"/>
      </style_property>
    </rule>
  </style>
  <style name="space">
    <rule>
      <style_context token="IDENTIFIER, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="(, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="LITERAL, ,"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=",, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="BIN_OP"/>
      <style_property space1="true" space2="true"/>
    </rule>
  </style>
  <style name="comment_syntax"/>
  <style name="arrangement">
    <rule>
      <style_context type="class" statistic="methodDeclarationList=1"/>
      <style_property>
        <member_list name="methodDeclarationList">
          <feature statistic="DEFAULT=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>LEXI_ORDER</logical_order>
          </order>
        </member_list>
      </style_property>
    </rule>
  </style>
  <style name="comment_density">
    <rule>
      <style_property density="0.0"/>
    </rule>
  </style>
  <style name="line_statement">
    <rule>
      <style_context maxTextLength="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <style_context type1="DECLARATION_STMT" type2="DECLARATION_STMT" minTextLength="0" hasSameDecType="true"/>
      <style_property newlines="0"/>
    </rule>
  </style>
  <style name="structure_preference">
    <rule>
      <style_context id="7" category="Continuous assignments or calls preferences"/>
      <style_property preferenceIndex="0"/>
    </rule>
  </style>
  <style name="literal_usage"/>
  <style name="body_layout"/>
</program_style>
