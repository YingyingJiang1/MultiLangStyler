<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="arrangement"/>
  <style name="line_statement">
    <rule>
      <style_context maxTextLength="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <style_context type1="COMPOUND_STMT" type2="COMPOUND_STMT" minCodeBockLines="0"/>
      <style_property newlines="0"/>
    </rule>
  </style>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" "/>
    </rule>
  </style>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>ANY_BODY</block_type>
        <body_type>ANY</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
  </style>
  <style name="structure_preference"/>
  <style name="space">
    <rule>
      <style_context token="IDENTIFIER, ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, }"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="), )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, )"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, }"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ,"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="UNARY_OP, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, IDENTIFIER"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="(, UNARY_OP"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, &lt;EOF&gt;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="BIN_OP"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="}, KEYWORD"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token=",, LITERAL"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="(, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="LITERAL, )"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="), ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, ("/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="{, COMMENT"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="DOT"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="{, IDENTIFIER"/>
      <style_property space1="true" space2="false"/>
    </rule>
  </style>
  <style name="numeric_literal">
    <rule>
      <style_context literal_type="INT_NUMBER"/>
      <style_property declare_constant_for_use="false"/>
    </rule>
  </style>
</program_style>
