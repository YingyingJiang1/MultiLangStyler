<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format">
    <rule>
      <style_context name_type="METHOD"/>
      <style_property case_format="LOWER_CAMEL" start_with_underscore="false" max_length="19"/>
    </rule>
    <rule>
      <style_context name_type="TYPE"/>
      <style_property case_format="UPPER_CAMEL" start_with_underscore="false" max_length="8"/>
    </rule>
    <rule>
      <style_context name_type="LOCAL_VARIABLE"/>
      <style_property case_format="LOWER_CAMEL" start_with_underscore="false" max_length="14"/>
    </rule>
    <rule>
      <style_context name_type="CONSTRUCTOR"/>
      <style_property case_format="UPPER_CAMEL" start_with_underscore="false" max_length="3"/>
    </rule>
  </style>
  <style name="if_else_body_order"/>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" "/>
    </rule>
  </style>
  <style name="optional_brace">
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property use_brace="true"/>
    </rule>
  </style>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
  </style>
  <style name="multi_branch"/>
  <style name="declaration_location">
    <rule>
      <style_property>
        <location>BLOCK_START</location>
      </style_property>
    </rule>
  </style>
  <style name="declaration_number">
    <rule>
      <style_context has_comment="false"/>
      <style_property variable_count="4"/>
    </rule>
  </style>
  <style name="most_complex_expression"/>
  <style name="lineWrapping">
    <rule>
      <style_context/>
      <style_property/>
    </rule>
    <rule>
      <style_context/>
      <style_property/>
    </rule>
  </style>
  <style name="space">
    <rule>
      <style_context token="IDENTIFIER, ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="UNARY_OP, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="RIGHT_ANGLE_BRACKET, ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ,"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="LEFT_ANGLE_BRACKET, RIGHT_ANGLE_BRACKET"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=",, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="BIN_OP"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="LEFT_ANGLE_BRACKET, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, ("/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="RIGHT_ANGLE_BRACKET, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="DOT"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="[, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=",, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="], IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="}, }"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, }"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="[, ]"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, ["/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, UNARY_OP"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, RIGHT_ANGLE_BRACKET"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="], )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="{, KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="], ,"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="UNARY_OP, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="COLON"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ["/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ]"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, LEFT_ANGLE_BRACKET"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="{, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
  </style>
  <style name="parameter_order">
    <rule>
      <style_property>
        <order>LENGTH_ASC_ORDER</order>
        <separate_same_type>true</separate_same_type>
      </style_property>
    </rule>
  </style>
  <style name="comment_syntax"/>
  <style name="arrangement">
    <rule>
      <style_context type="class" statistic="constructorDeclarationList=1, fieldDeclarationList=2"/>
      <style_property>
        <member_list name="fieldDeclarationList">
          <feature statistic="DEFAULT=2"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>LEXI_ORDER</logical_order>
          </order>
        </member_list>
        <member_list name="constructorDeclarationList">
          <feature statistic="DEFAULT=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>LEXI_ORDER</logical_order>
          </order>
        </member_list>
      </style_property>
    </rule>
    <rule>
      <style_context type="class" statistic="methodDeclarationList=1"/>
      <style_property>
        <member_list name="methodDeclarationList">
          <feature statistic="PUBLIC=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>PUBLIC</column1>
            </modifier_order>
          </order>
        </member_list>
      </style_property>
    </rule>
  </style>
  <style name="comment_density"/>
  <style name="line_statement">
    <rule>
      <style_context maxTextLength="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <style_context type1="MEMBER_LIST" type2="MEMBER_LIST" minCodeBockLines="0"/>
      <style_property newlines="2"/>
    </rule>
    <rule>
      <style_context type1="COMPOUND_STMT" type2="COMPOUND_STMT" minCodeBockLines="0"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="COMPOUND_STMT" type2="SINGLE_STMT" minCodeBockLines="0"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="SINGLE_STMT" type2="COMPOUND_STMT" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="TYPE_DEC" type2="TYPE_DEC" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="FILE_HEAD_DEC" type2="TYPE_DEC" minCodeBockLines="0"/>
      <style_property newlines="2"/>
    </rule>
  </style>
  <style name="modifier_order">
    <rule>
      <style_property order="access_control"/>
    </rule>
  </style>
  <style name="structure_preference">
    <rule>
      <style_context id="1" category="Increment or decrement preferences"/>
      <style_property preferenceIndex="2"/>
    </rule>
    <rule>
      <style_context id="2" category="Increment or decrement preferences"/>
      <style_property preferenceIndex="2"/>
    </rule>
    <rule>
      <style_context id="3" category="Assignment statement preferences"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="7" category="Continuous assignments or calls preferences"/>
      <style_property preferenceIndex="0"/>
    </rule>
    <rule>
      <style_context id="9" category="Loops"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="11" category="Loops"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="14" category="Loops"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="19" category="Operator preferences"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="20" category="Operator preferences"/>
      <style_property preferenceIndex="0"/>
    </rule>
    <rule>
      <style_context id="24" category="Return statements"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="25" category="Array declaration style"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="26" category="Array declaration style"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="30" category="Continue preferences"/>
      <style_property preferenceIndex="2"/>
    </rule>
    <rule>
      <style_context id="32" category="Redundant code"/>
      <style_property preferenceIndex="0"/>
    </rule>
  </style>
  <style name="literal_usage"/>
  <style name="unused_variable">
    <rule>
      <style_property hasUnusedVar="false"/>
    </rule>
    <rule>
      <style_context codeLevel="CONSTRUCTOR"/>
      <style_property hasUnusedVar="true"/>
    </rule>
    <rule>
      <style_context codeLevel="TYPE"/>
      <style_property hasUnusedVar="true"/>
    </rule>
    <rule>
      <style_context codeLevel="METHOD"/>
      <style_property hasUnusedVar="true"/>
    </rule>
    <rule>
      <style_context codeLevel="FIELD"/>
      <style_property hasUnusedVar="true"/>
    </rule>
  </style>
  <style name="body_layout"/>
</program_style>
