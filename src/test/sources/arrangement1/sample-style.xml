<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format">
    <rule>
      <style_context name_type="PARAMETER"/>
      <style_property case_format="LOWER_CAMEL" start_with_underscore="false" max_length="18"/>
    </rule>
    <rule>
      <style_context name_type="CONSTRUCTOR"/>
      <style_property case_format="UPPER_CAMEL" start_with_underscore="false" max_length="26"/>
    </rule>
    <rule>
      <style_context name_type="METHOD"/>
      <style_property case_format="LOWER_CAMEL" start_with_underscore="false" max_length="14"/>
    </rule>
    <rule>
      <style_context name_type="FIELD"/>
      <style_property case_format="LOWER_UNDERSCORE" start_with_underscore="false" max_length="34"/>
    </rule>
    <rule>
      <style_context name_type="TYPE"/>
      <style_property case_format="UPPER_CAMEL" start_with_underscore="false" max_length="29"/>
    </rule>
  </style>
  <style name="if_else_body_order"/>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" "/>
    </rule>
  </style>
  <style name="optional_brace">
    <rule>
      <style_context>
        <block_type>MULTI_BLOCK_STMT_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property use_brace="true"/>
    </rule>
  </style>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>ARRAY_INITIALIZER_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
  </style>
  <style name="multi_branch"/>
  <style name="declaration_location">
    <rule>
      <style_property>
        <location>BLOCK_START</location>
      </style_property>
    </rule>
  </style>
  <style name="declaration_number">
    <rule>
      <style_context has_comment="false"/>
      <style_property variable_count="1"/>
    </rule>
  </style>
  <style name="most_complex_expression"/>
  <style name="space">
    <rule>
      <style_context token="IDENTIFIER, ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="LITERAL, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ,"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token=",, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="BIN_OP"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="}, COMMENT"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, ("/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token=";, COMMENT"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="DOT"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=",, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="), )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, }"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="{, }"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, }"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, @"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, COMMENT"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, LITERAL"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="UNARY_OP, LITERAL"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="{, KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="), {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="), ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="{, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
  </style>
  <style name="parameter_order">
    <rule>
      <style_property>
        <order>LENGTH_DESC_ORDER</order>
      </style_property>
    </rule>
  </style>
  <style name="comment_syntax">
    <rule>
      <style_context comment_type="SINGLE_LINE"/>
      <style_property syntax="//"/>
    </rule>
  </style>
  <style name="arrangement">
    <rule>
      <style_context type="interface" statistic="methodDeclarationList=3"/>
      <style_property>
        <member_list name="methodDeclarationList">
          <feature statistic="DEFAULT=3"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>LEXI_ORDER</logical_order>
          </order>
        </member_list>
      </style_property>
    </rule>
    <rule>
      <style_context type="class" statistic="methodDeclarationList=3, typeDeclarationList=3, constructorDeclarationList=1, fieldDeclarationList=4, initializerList=1"/>
      <style_property>
        <member_list name="fieldDeclarationList">
          <feature statistic="PRIVATE=1,PUBLIC=3,STATIC=4,FINAL=4"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>PRIVATE,PUBLIC</column1>
              <column2>STATIC</column2>
              <column3>FINAL</column3>
            </modifier_order>
          </order>
        </member_list>
        <member_list name="typeDeclarationList">
          <feature statistic="DEFAULT=1,STATIC=2"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_ORDER</logical_order>
            <modifier_order>
              <column1>STATIC</column1>
            </modifier_order>
          </order>
        </member_list>
        <member_list name="initializerList">
          <feature statistic="STATIC=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>STATIC</column1>
            </modifier_order>
          </order>
        </member_list>
        <member_list name="constructorDeclarationList">
          <feature statistic="PRIVATE=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>PRIVATE</column1>
            </modifier_order>
          </order>
        </member_list>
        <member_list name="methodDeclarationList">
          <feature statistic="PUBLIC=3,STATIC=3"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_ORDER</logical_order>
            <modifier_order>
              <column1>PUBLIC</column1>
              <column2>STATIC</column2>
            </modifier_order>
          </order>
        </member_list>
      </style_property>
    </rule>
    <rule>
      <style_context type="class" statistic="methodDeclarationList=3, constructorDeclarationList=1"/>
      <style_property>
        <member_list name="constructorDeclarationList">
          <feature statistic="DEFAULT=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>LEXI_ORDER</logical_order>
          </order>
        </member_list>
        <member_list name="methodDeclarationList">
          <feature statistic="PUBLIC=3"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>PUBLIC</column1>
            </modifier_order>
          </order>
        </member_list>
      </style_property>
    </rule>
  </style>
  <style name="comment_density">
    <rule>
      <style_property density="0.11904761904761904"/>
    </rule>
  </style>
  <style name="line_statement">
    <rule>
      <style_context maxTextLength="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <style_context type1="MEMBER_LIST" type2="MEMBER_LIST" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="FUNCTION_DEC" type2="FUNCTION_DEC" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="FILE_HEAD_DEC" type2="importDeclarationList" minCodeBockLines="0"/>
      <style_property newlines="2"/>
    </rule>
    <rule>
      <style_context type1="annotation" type2="KEYWORD" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="FILE_HEAD_DEC" type2="FILE_HEAD_DEC" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="TYPE_DEC" type2="TYPE_DEC" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="importDeclarationList" type2="TYPE_DEC" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="modifier_order">
    <rule>
      <style_property order="access_control, static, final"/>
    </rule>
  </style>
  <style name="structure_preference">
    <rule>
      <style_context id="17" category="Check then assign preferences"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="1" category="Increment or decrement preferences"/>
      <style_property preferenceIndex="2"/>
    </rule>
    <rule>
      <style_context id="2" category="Increment or decrement preferences"/>
      <style_property preferenceIndex="2"/>
    </rule>
    <rule>
      <style_context id="19" category="Operator preferences"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="20" category="Operator preferences"/>
      <style_property preferenceIndex="0"/>
    </rule>
    <rule>
      <style_context id="23" category="Return statements"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="7" category="Continuous assignments or calls preferences"/>
      <style_property preferenceIndex="0"/>
    </rule>
    <rule>
      <style_context id="24" category="Return statements"/>
      <style_property preferenceIndex="1"/>
    </rule>
  </style>
  <style name="unused_variable">
    <rule>
      <style_property hasUnusedVar="false"/>
    </rule>
    <rule>
      <style_context codeLevel="PARAMETER"/>
      <style_property hasUnusedVar="true"/>
    </rule>
    <rule>
      <style_context codeLevel="METHOD"/>
      <style_property hasUnusedVar="true"/>
    </rule>
    <rule>
      <style_context codeLevel="CONSTRUCTOR"/>
      <style_property hasUnusedVar="true"/>
    </rule>
    <rule>
      <style_context codeLevel="FIELD"/>
      <style_property hasUnusedVar="true"/>
    </rule>
    <rule>
      <style_context codeLevel="TYPE"/>
      <style_property hasUnusedVar="true"/>
    </rule>
  </style>
  <style name="body_layout"/>
</program_style>
