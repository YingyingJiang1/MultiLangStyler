          <feature statistic="PRIVATE=1,PUBLIC=3,STATIC=4,FINAL=4"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>PRIVATE,PUBLIC</column1>
              <column2>STATIC</column2>
              <column3>FINAL</column3>
            </modifier_order>
          </order>
        </member_list>
        <member_list name="initializerList">
