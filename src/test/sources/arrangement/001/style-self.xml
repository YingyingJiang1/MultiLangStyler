<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format">
    <rule>
      <style_context name_type="CONSTRUCTOR"/>
      <style_property case_format="UPPER_CAMEL" start_with_underscore="false" max_length="21"/>
    </rule>
    <rule>
      <style_context name_type="METHOD"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="12"/>
    </rule>
    <rule>
      <style_context name_type="LOCAL_VARIABLE"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="12"/>
    </rule>
    <rule>
      <style_context name_type="FIELD"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="12"/>
    </rule>
    <rule>
      <style_context name_type="TYPE"/>
      <style_property case_format="UPPER_CAMEL" start_with_underscore="false" max_length="12"/>
    </rule>
    <rule>
      <style_context name_type="PARAMETER"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="12"/>
    </rule>
  </style>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" "/>
    </rule>
  </style>
  <style name="optional_brace">
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property use_brace="false"/>
    </rule>
  </style>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>MULTI_BLOCK_STMT_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
  </style>
  <style name="declaration_location">
    <rule>
      <style_property>
        <avgLineDis2firstUse>1.4</avgLineDis2firstUse>
        <location>NEAR_USE</location>
      </style_property>
    </rule>
  </style>
  <style name="lineWrapping">
    <rule>
      <style_context/>
      <style_property/>
    </rule>
    <rule>
      <style_context/>
      <style_property/>
    </rule>
  </style>
