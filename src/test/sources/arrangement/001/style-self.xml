  <style name="arrangement">
    <rule>
      <style_context type="class" statistic="methodDeclarationList=4, typeDeclarationList=1, constructorDeclarationList=2, fieldDeclarationList=1"/>
      <style_property>
        <member_list name="fieldDeclarationList">
          <feature statistic="DEFAULT=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>LEXI_ORDER</logical_order>
          </order>
        </member_list>
        <member_list name="constructorDeclarationList">
          <feature statistic="PUBLIC=2"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>PUBLIC</column1>
            </modifier_order>
          </order>
        </member_list>
        <member_list name="methodDeclarationList">
          <feature statistic="PUBLIC=4"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_ORDER</logical_order>
            <modifier_order>
              <column1>PUBLIC</column1>
            </modifier_order>
          </order>
        </member_list>
        <member_list name="typeDeclarationList">
          <feature statistic="STATIC=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>STATIC</column1>
            </modifier_order>
          </order>
        </member_list>
      </style_property>
    </rule>
    <rule>
      <style_context type="class" statistic="methodDeclarationList=1, constructorDeclarationList=3"/>
      <style_property>
        <member_list name="constructorDeclarationList">
          <feature statistic="PUBLIC=3"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>PUBLIC</column1>
            </modifier_order>
          </order>
        </member_list>
        <member_list name="methodDeclarationList">
          <feature statistic="PUBLIC=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>PUBLIC</column1>
            </modifier_order>
          </order>
        </member_list>
      </style_property>
    </rule>
    <rule>
      <style_context type="class" statistic="methodDeclarationList=6, fieldDeclarationList=5"/>
      <style_property>
        <member_list name="fieldDeclarationList">
          <feature statistic="PRIVATE=5,STATIC=5"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_ORDER</logical_order>
            <modifier_order>
              <column1>PRIVATE</column1>
              <column2>STATIC</column2>
            </modifier_order>
          </order>
        </member_list>
        <member_list name="methodDeclarationList">
