<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="arrangement"/>
  <style name="line_statement">
    <rule>
      <style_context maxTextLength="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <style_context type1="COMPOUND_STMT" type2="SINGLE_STMT" minCodeBockLines="0"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="SINGLE_STMT" type2="COMPOUND_STMT" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="if_else_body_order">
    <rule>
      <style_property short_body_comes_first="true"/>
    </rule>
  </style>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" "/>
    </rule>
  </style>
  <style name="modifier_order">
    <rule>
      <style_property order="access_control"/>
    </rule>
  </style>
  <style name="declaration-number"/>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>MULTI_BLOCK_STMT_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
  </style>
  <style name="structure_preference">
    <rule>
      <style_context id="25" category="Return statements"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="26" category="Return statements"/>
      <style_property preferenceIndex="1"/>
    </rule>
  </style>
  <style name="space">
    <rule>
      <style_context token="IDENTIFIER, ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ,"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, {"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token=",, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="BIN_OP"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, ("/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="DOT"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, }"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="), )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, }"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="UNARY_OP, LITERAL"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, &lt;EOF&gt;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, KEYWORD"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, IDENTIFIER"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="LITERAL, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), {"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="{, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, IDENTIFIER"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, UNARY_OP"/>
      <style_property space1="true" space2="true"/>
    </rule>
  </style>
  <style name="numeric_literal"/>
</program_style>
