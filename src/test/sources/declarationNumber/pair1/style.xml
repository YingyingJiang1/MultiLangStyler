<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="arrangement">
    <rule>
      <style_context type="class" statistic="methodDeclarationList=1"/>
      <style_property>
        <member_list name="methodDeclarationList">
          <feature statistic="PUBLIC=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>PUBLIC</column1>
            </modifier_order>
          </order>
        </member_list>
      </style_property>
    </rule>
  </style>
  <style name="line_statement">
    <rule>
      <style_context maxTextLength="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <style_context type1="FILE_HEAD_DEC" type2="importDeclarationList" minCodeBockLines="0"/>
      <style_property newlines="2"/>
    </rule>
    <rule>
      <style_context type1="annotation" type2="KEYWORD" minCodeBockLines="0"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="FILE_HEAD_DEC" type2="FILE_HEAD_DEC" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="importDeclarationList" type2="TYPE_DEC" minCodeBockLines="0"/>
      <style_property newlines="2"/>
    </rule>
  </style>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" "/>
    </rule>
  </style>
  <style name="modifier_order">
    <rule>
      <style_property order="annotation, access_control"/>
    </rule>
  </style>
  <style name="declaration-number">
    <rule>
      <style_context has_comment="false"/>
      <style_property variable_count="1"/>
    </rule>
  </style>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="true" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
  </style>
  <style name="structure_preference"/>
  <style name="space">
    <rule>
      <style_context token="IDENTIFIER, ("/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, )"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="(, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="RIGHT_ANGLE_BRACKET, ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="LITERAL, ;"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ,"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, IDENTIFIER"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="BIN_OP"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token=",, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="LEFT_ANGLE_BRACKET, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, {"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="RIGHT_ANGLE_BRACKET, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="DOT"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="], IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, }"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, }"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="[, ]"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="{, @"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="UNARY_OP, LITERAL"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, RIGHT_ANGLE_BRACKET"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, &lt;EOF&gt;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="{, KEYWORD"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token=";, KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, IDENTIFIER"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ["/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="), ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), {"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, KEYWORD"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, LEFT_ANGLE_BRACKET"/>
      <style_property space1="true" space2="false"/>
    </rule>
    <rule>
      <style_context token="[, LITERAL"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="], ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
  </style>
  <style name="numeric_literal">
    <rule>
      <style_context literal_type="INT_NUMBER"/>
      <style_property declare_constant_for_use="false"/>
    </rule>
  </style>
</program_style>
