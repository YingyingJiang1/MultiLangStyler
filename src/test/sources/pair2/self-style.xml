<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="arrangement">
    <rule>
      <style_context type="class" statistic="methodDeclarationList=1"/>
      <style_property>
        <member_list name="methodDeclarationList">
          <feature statistic="PUBLIC=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>PUBLIC</column1>
            </modifier_order>
          </order>
        </member_list>
      </style_property>
    </rule>
  </style>
  <style name="line_statement">
    <rule>
      <style_context maxTextLength="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <style_context type1="COMPOUND_STMT" type2="COMPOUND_STMT" minCodeBockLines="0"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="COMPOUND_STMT" type2="SINGLE_STMT" minCodeBockLines="0"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="SINGLE_STMT" type2="COMPOUND_STMT" minCodeBockLines="0"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="FILE_HEAD_DEC" type2="TYPE_DEC" minCodeBockLines="0"/>
      <style_property newlines="2"/>
    </rule>
  </style>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" "/>
    </rule>
  </style>
  <style name="modifier_order">
    <rule>
      <style_property order=""/>
    </rule>
  </style>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>MULTI_BLOCK_STMT_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>ARRAY_INITIALIZER_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="false" beforeRB="false" afterRB="false"/>
    </rule>
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="true" afterRB="true"/>
    </rule>
  </style>
  <style name="structure_preference"/>
