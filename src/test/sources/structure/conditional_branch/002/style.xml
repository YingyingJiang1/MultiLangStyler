<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format">
    <rule>
      <style_context name_type="TYPE"/>
      <style_property case_format="UPPER_CAMEL" start_with_underscore="false" max_length="4"/>
    </rule>
    <rule>
      <style_context name_type="LOCAL_VARIABLE"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="10"/>
    </rule>
    <rule>
      <style_context name_type="PARAMETER"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="4"/>
    </rule>
    <rule>
      <style_context name_type="METHOD"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="4"/>
    </rule>
  </style>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" "/>
    </rule>
  </style>
  <style name="optional_brace"/>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>MULTI_BLOCK_STMT_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="false"/>
    </rule>
  </style>
  <style name="declaration_location">
    <rule>
      <style_property>
        <avgLineDis2firstUse>4.33</avgLineDis2firstUse>
        <location>BLOCK_START</location>
      </style_property>
    </rule>
  </style>
  <style name="lineWrapping">
    <rule>
      <style_context/>
      <style_property/>
    </rule>
    <rule>
      <style_context/>
      <style_property/>
    </rule>
  </style>
  <style name="space">
    <rule>
      <style_context token="IDENTIFIER, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="UNARY_OP, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, LITERAL"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="[, ]"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="LITERAL, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, UNARY_OP"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="BIN_OP"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="}, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="(, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="LITERAL, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ["/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, ("/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="DOT"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="], IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
  </style>
  <style name="arrangement">
    <rule>
      <style_context type="class" statistic="methodDeclarationList=1"/>
      <style_property>
        <member_list name="methodDeclarationList">
          <feature statistic="PUBLIC=1,STATIC=1"/>
          <order allowedOrderDeviation="0.3">
            <logical_order>MODIFIER_LEXI_ORDER</logical_order>
            <modifier_order>
              <column1>PUBLIC</column1>
              <column2>STATIC</column2>
            </modifier_order>
          </order>
        </member_list>
      </style_property>
    </rule>
  </style>
  <style name="comment_density">
    <rule>
      <style_property density="0.0"/>
    </rule>
  </style>
  <style name="line_statement">
    <rule>
      <style_context maxTextLength="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <style_context type1="DECLARATION_STMT" type2="DECLARATION_STMT" minTextLength="0" hasSameDecType="false"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="LOOP_STMT" type2="EXPRESSION_STMT" minTextLength="190"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="importDeclarationList" type2="TYPE_DEC"/>
      <style_property newlines="2"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="LOOP_STMT" minTextLength="190"/>
      <style_property newlines="2"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="CONDITIONAL_STMT" minTextLength="161"/>
      <style_property newlines="2"/>
    </rule>
    <rule>
      <style_context type1="EXPRESSION_STMT" type2="EXPRESSION_STMT" minTextLength="0"/>
      <style_property newlines="0"/>
    </rule>
  </style>
  <style name="structure_preference">
    <rule>
      <style_context id="1" category="Increment or decrement preferences"/>
      <style_property preferenceIndex="0"/>
    </rule>
    <rule>
      <style_context id="22" category="Literal position in bool expression"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="7" category="Continuous assignments or calls preferences"/>
      <style_property preferenceIndex="0"/>
    </rule>
    <rule>
      <style_context id="8" category="Loops"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="9" category="Loops"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="31" category="Continue preferences"/>
      <style_property preferenceIndex="2"/>
    </rule>
    <rule>
      <style_context id="32" category="Redundant code"/>
      <style_property preferenceIndex="1"/>
    </rule>
  </style>
  <style name="body_layout"/>
</program_style>
