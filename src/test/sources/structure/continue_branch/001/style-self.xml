<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format"/>
  <style name="indention">
    <rule>
      <style_property indentionUnit="1" indentionType="\t"/>
    </rule>
  </style>
  <style name="optional_brace">
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property use_brace="false"/>
    </rule>
  </style>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>MULTI_BLOCK_STMT_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="false"/>
    </rule>
  </style>
  <style name="declaration_location"/>
  <style name="lineWrapping">
    <rule>
      <style_context attr="CODE"/>
      <style_property variance="0.0" maxLen="0" maxLenBefore="0" succeedLoc="0">
        <breakLoc reg="," after="true"/>
        <breakLoc reg="[?:]" after="true"/>
        <breakLoc reg="[.]" after="false"/>
        <breakLoc reg="[&amp;]{2}" after="true"/>
        <breakLoc reg="[|]{2}" after="true"/>
        <breakLoc reg="[-+*/%&amp;|^]" after="true"/>
        <breakLoc reg="[=]{2,3}" after="true"/>
        <breakLoc reg="[-+*/%&amp;|^]=|&lt;&lt;=|&gt;&gt;=|&gt;&gt;&gt;=" after="true"/>
        <breakLoc reg="&lt;|&lt;=|&gt;|&gt;=|==|!=" after="true"/>
        <breakLoc reg="[(]" after="true"/>
      </style_property>
    </rule>
    <rule>
      <style_context attr="COMMENT"/>
      <style_property variance="0.0" maxLen="0" maxLenBefore="0" succeedLoc="0">
        <breakLoc reg=" +|[,.]" after="true"/>
      </style_property>
    </rule>
  </style>
  <style name="space">
    <rule>
      <style_context token="IDENTIFIER, ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, LITERAL"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="LITERAL, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="BIN_OP"/>
      <style_property space1="true" space2="true"/>
    </rule>
    <rule>
      <style_context token="), IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, ("/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="DOT"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="], IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="), )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, KEYWORD"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="[, ]"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, UNARY_OP"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="}, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="UNARY_OP, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="(, IDENTIFIER"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="LITERAL, )"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="), {"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="), ;"/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER, ["/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="KEYWORD, KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token=";, IDENTIFIER"/>
      <style_property space1="false" space2="true"/>
    </rule>
  </style>
  <style name="arrangement"/>
  <style name="comment_density">
    <rule>
      <style_property density="0.0"/>
    </rule>
  </style>
  <style name="line_statement">
    <rule>
      <style_context maxTextLength="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <style_context type1="DECLARATION_STMT" type2="DECLARATION_STMT" minTextLength="0" hasSameDecType="false"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="EXPRESSION_STMT" type2="CONDITIONAL_STMT" minTextLength="70"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="EXPRESSION_STMT" type2="DECLARATION_STMT" minTextLength="0"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="LOOP_STMT" minTextLength="151"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="EXPRESSION_STMT" minTextLength="0"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="EXPRESSION_STMT" type2="EXPRESSION_STMT" minTextLength="0"/>
      <style_property newlines="0"/>
    </rule>
  </style>
  <style name="structure_preference">
    <rule>
      <style_context id="18" category="Operator preferences"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="22" category="Literal position in bool expression"/>
      <style_property preferenceIndex="0"/>
    </rule>
    <rule>
      <style_context id="7" category="Continuous assignments or calls preferences"/>
      <style_property preferenceIndex="0"/>
    </rule>
    <rule>
      <style_context id="30" category="Continue preferences"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="31" category="Continue preferences"/>
      <style_property preferenceIndex="2"/>
    </rule>
  </style>
  <style name="body_layout">
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property compactStyle="false"/>
    </rule>
    <rule>
      <style_context>
        <block_type>MULTI_BLOCK_STMT_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property compactStyle="true"/>
    </rule>
  </style>
</program_style>
