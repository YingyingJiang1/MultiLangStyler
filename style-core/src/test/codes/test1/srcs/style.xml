<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format"/>
  <style name="newline">
    <rule>
      <style_context verticalVector="[]" horizontalVector="[StatementContext, StatementContext, RBRACE]" verticalLengthVector="[]" horizontalLengthVector="[90, 340, 0]" verticalSP="-1" horizontalSP="0"/>
      <style_property newlines="1" hwsStr="      "/>
    </rule>
    <rule>
      <style_context verticalVector="[]" horizontalVector="[ExpressionContext, SEMI]" verticalLengthVector="[]" horizontalLengthVector="[20, 0]" verticalSP="-1" horizontalSP="0"/>
      <style_property newlines="0" hwsStr=""/>
    </rule>
  </style>
  <style name="if_else_body_order">
    <rule>
      <style_property short_body_comes_first="false"/>
    </rule>
  </style>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" " indentEmptyLine="false" topHierarchyIndention="0"/>
    </rule>
  </style>
  <style name="optional_brace">
    <rule>
      <style_context>
        <block_type>MULTI_BLOCK_STMT_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property use_brace="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property use_brace="true"/>
    </rule>
  </style>
  <style name="modifier_order">
    <rule>
      <style_property order="annotation, access_control"/>
    </rule>
  </style>
  <style name="expression_complexity">
    <rule>
      <style_context expType="INITIALIZER_EXP"/>
      <style_property>
        <maxComplexity depth="13.0"/>
        <avgComplexity depth="8.409090909090908"/>
      </style_property>
    </rule>
    <rule>
      <style_context expType="TOP_EXP"/>
      <style_property>
        <maxComplexity depth="23.0"/>
        <avgComplexity depth="9.363636363636363"/>
      </style_property>
    </rule>
    <rule>
      <style_context expType="CONDITIONAL_EXP"/>
      <style_property>
        <maxComplexity depth="9.0"/>
        <avgComplexity depth="5.318181818181818"/>
      </style_property>
    </rule>
  </style>
  <style name="structure_preference">
    <rule>
      <style_context id="18" category="Operator preferences"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="19" category="Literal position in bool expression"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="23" category="Continue preferences"/>
      <style_property preferenceIndex="2"/>
    </rule>
    <rule>
      <style_context id="14" category="Check then assign preferences"/>
      <style_property preferenceIndex="1"/>
    </rule>
  </style>
  <style name="declaration_layout"/>
  <style name="declaration_location"/>
  <style name="space">
    <rule>
      <style_context token="IDENTIFIER ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token="( ("/>
      <style_property space1="false" space2="false"/>
    </rule>
    <rule>
      <style_context token=") KEYWORD"/>
      <style_property space1="false" space2="true"/>
    </rule>
    <rule>
      <style_context token="IDENTIFIER )"/>
      <style_property space1="false" space2="false"/>
    </rule>
  </style>
</program_style>
