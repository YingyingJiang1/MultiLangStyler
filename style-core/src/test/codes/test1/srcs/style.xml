<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format"/>
  <style name="if_else_body_order">
    <rule>
      <style_property short_body_comes_first="false"/>
    </rule>
  </style>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" " indentEmptyLine="false" topHierarchyIndention="0"/>
    </rule>
  </style>
  <style name="optional_brace">
    <rule>
      <style_context>
        <block_type>MULTI_BLOCK_STMT_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property use_brace="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property use_brace="true"/>
    </rule>
  </style>
  <style name="expression_complexity">
    <rule>
      <style_context expType="CONDITIONAL_EXP"/>
      <style_property>
        <maxComplexity depth="9.0"/>
        <avgComplexity depth="5.318181818181818"/>
      </style_property>
    </rule>
    <rule>
      <style_context expType="INITIALIZER_EXP"/>
      <style_property>
        <maxComplexity depth="13.0"/>
        <avgComplexity depth="8.409090909090908"/>
      </style_property>
    </rule>
    <rule>
      <style_context expType="TOP_EXP"/>
      <style_property>
        <maxComplexity depth="23.0"/>
        <avgComplexity depth="9.363636363636363"/>
      </style_property>
    </rule>
  </style>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>DO_WHILE_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="false"/>
    </rule>
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>NORMAL_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="true"/>
    </rule>
  </style>
  <style name="declaration_layout"/>
  <style name="declaration_location"/>
  <style name="lineWrapping">
    <rule>
      <style_context attr="CODE"/>
      <style_property variance="0.0" maxLen="0" maxLenBefore="0" succeedLoc="0">
        <breakLoc reg="," after="true"/>
        <breakLoc reg="[?:]" after="true"/>
        <breakLoc reg="[.]" after="false"/>
        <breakLoc reg="[&amp;]{2}" after="true"/>
        <breakLoc reg="[|]{2}" after="true"/>
        <breakLoc reg="[-+*/%&amp;|^]" after="true"/>
        <breakLoc reg="[=]{2,3}" after="true"/>
        <breakLoc reg="[-+*/%&amp;|^]=|&lt;&lt;=|&gt;&gt;=|&gt;&gt;&gt;=" after="true"/>
        <breakLoc reg="&lt;|&lt;=|&gt;|&gt;=|==|!=" after="true"/>
        <breakLoc reg="[(]" after="true"/>
      </style_property>
    </rule>
    <rule>
      <style_context attr="COMMENT"/>
      <style_property variance="0.0" maxLen="0" maxLenBefore="0" succeedLoc="0">
        <breakLoc reg=" +|[,.]" after="true"/>
      </style_property>
    </rule>
  </style>
  <style name="space">
