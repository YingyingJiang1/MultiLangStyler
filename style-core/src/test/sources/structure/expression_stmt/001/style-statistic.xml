<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format">
    <rule>
      <context number="1"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="2"/>
      <property statistic="{1=1}"/>
    </rule>
    <rule>
      <context number="3"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="4"/>
      <property statistic="{2=2}"/>
    </rule>
    <rule>
      <context number="5"/>
      <property statistic="{1=1}"/>
    </rule>
    <rule>
      <context number="6"/>
      <property statistic="{1=17}"/>
    </rule>
  </style>
  <style name="line_statement">
    <rule>
      <context number="1"/>
      <property statistic="{1=2}"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <context number="1"/>
      <property statistic="{1=1}"/>
    </rule>
    <rule>
      <context number="2"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="3"/>
      <property statistic="{1=1}"/>
    </rule>
    <rule>
      <context number="4"/>
      <property statistic="{2=4}"/>
    </rule>
    <rule>
      <context number="5"/>
      <property statistic="{2=1}"/>
    </rule>
    <rule>
      <context number="6"/>
      <property statistic="{2=2}"/>
    </rule>
    <rule>
      <context number="7"/>
      <property statistic="{2=1}"/>
    </rule>
    <rule>
      <context number="8"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="9"/>
      <property statistic="{2=1, 3=1}"/>
    </rule>
    <rule>
      <context number="10"/>
      <property statistic="{2=1}"/>
    </rule>
    <rule>
      <context number="11"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="12"/>
      <property statistic="{1=1}"/>
    </rule>
    <rule>
      <context number="13"/>
      <property statistic="{1=1}"/>
    </rule>
    <rule>
      <context number="14"/>
      <property statistic="{3=1}"/>
    </rule>
    <rule>
      <context number="15"/>
      <property statistic="{3=2}"/>
    </rule>
    <rule>
      <context number="16"/>
      <property statistic="{2=1}"/>
    </rule>
    <rule>
      <context number="17"/>
      <property statistic="{1=1}"/>
    </rule>
  </style>
  <style name="if_else_body_order"/>
  <style name="indention">
    <rule>
      <context number="1"/>
      <property statistic="{1=17, 2=20}"/>
    </rule>
  </style>
  <style name="optional_brace">
    <rule>
      <context number="1"/>
      <property statistic="{1=8}"/>
    </rule>
  </style>
  <style name="brace_format">
    <rule>
      <context number="1"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="2"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="3"/>
      <property statistic="{1=5}"/>
    </rule>
    <rule>
      <context number="4"/>
      <property statistic="{1=5}"/>
    </rule>
  </style>
  <style name="declaration_layout"/>
  <style name="declaration_location">
    <rule>
      <context number="1"/>
      <property statistic="{1=2}"/>
    </rule>
  </style>
  <style name="structure_preference">
    <rule>
      <context number="16"/>
      <property statistic="{0=10}"/>
    </rule>
    <rule>
      <context number="17"/>
      <property statistic="{1=1}"/>
    </rule>
    <rule>
      <context number="1"/>
      <property statistic="{3=1}"/>
    </rule>
    <rule>
      <context number="3"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="19"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="22"/>
      <property statistic="{2=1}"/>
    </rule>
  </style>
  <style name="body_layout"/>
  <style name="lineWrapping">
    <rule>
      <context number="1"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="2"/>
      <property statistic="{2=2}"/>
    </rule>
  </style>
</program_style>
