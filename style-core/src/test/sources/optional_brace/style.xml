<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name=""/>
  <style name="naming_format"/>
  <style name="newline"/>
  <style name="if_else_body_order"/>
  <style name="indention">
    <rule>
      <style_property indentionUnit="1" indentionType="\t" indentEmptyLine="false" topHierarchyIndention="0"/>
    </rule>
  </style>
  <style name="optional_brace">
    <rule>
      <style_context bodyType="STMT_BODY" bodySize="EMPTY" hasRightNeighbour="true"/>
      <style_property useBrace="false"/>
    </rule>
    <rule>
      <style_context bodyType="STMT_BODY" bodySize="ONE_SINGLE_STMT" hasRightNeighbour="true"/>
      <style_property useBrace="false"/>
    </rule>
    <rule>
      <style_context bodyType="STMT_BODY" bodySize="EMPTY" hasRightNeighbour="false"/>
      <style_property useBrace="false"/>
    </rule>
    <rule>
      <style_context bodyType="STMT_BODY" bodySize="ONE_SINGLE_STMT" hasRightNeighbour="false"/>
      <style_property useBrace="false"/>
    </rule>
  </style>
  <style name="modifier_order"/>
  <style name="structure_preference"/>
  <style name="body_layout"/>
  <style name="space"/>
  <style name="intra_newline"/>
</program_style>
