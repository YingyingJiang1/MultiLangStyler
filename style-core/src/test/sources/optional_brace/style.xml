    </rule>
  </style>
  <style name="optional_brace">
    <rule>
      <style_context bodyType="STMT_BODY" bodySize="ONE_SINGLE_STMT" hasRightNeighbour="false"/>
      <style_property useBrace="true"/>
    </rule>
    <rule>
      <style_context bodyType="STMT_BODY" bodySize="EMPTY" hasRightNeighbour="false"/>
      <style_property useBrace="true"/>
    </rule>
