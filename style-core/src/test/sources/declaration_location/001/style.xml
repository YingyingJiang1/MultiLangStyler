<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format">
    <rule>
      <style_context name_type="PARAMETER"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="4"/>
    </rule>
    <rule>
      <style_context name_type="TYPE"/>
      <style_property case_format="UPPER_CAMEL" start_with_underscore="false" max_length="4"/>
    </rule>
    <rule>
      <style_context name_type="METHOD"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="4"/>
    </rule>
    <rule>
      <style_context name_type="LOCAL_VARIABLE" IMPLICIT_CONST="IMPLICIT_CONST"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="7"/>
    </rule>
    <rule>
      <style_context name_type="LOCAL_VARIABLE"/>
      <style_property case_format="ALL_UPPER_CASE" start_with_underscore="false" max_length="10"/>
    </rule>
    <rule>
      <style_context name_type="LOCAL_VARIABLE"/>
      <style_property case_format="ALL_LOWER_CASE" start_with_underscore="false" max_length="10"/>
    </rule>
    <rule>
      <style_context name_type="LOCAL_VARIABLE"/>
      <style_property case_format="LOWER_CAMEL" start_with_underscore="false" max_length="10"/>
    </rule>
  </style>
  <style name="line_statement">
    <rule>
      <style_context maxTextLength="0"/>
      <style_property newlines="1"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <style_context type1="DECLARATION_STMT" type2="CONDITIONAL_STMT" minTextLength="0" hasComment="true"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="DECLARATION_STMT" minTextLength="0" hasSameDecType="true" hasComment="true"/>
      <style_property newlines="-1"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="DECLARATION_STMT" minTextLength="0" hasSameDecType="false" hasComment="false"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="importDeclarationList" type2="TYPE_DEC" hasComment="false"/>
      <style_property newlines="2"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="CONDITIONAL_STMT" minTextLength="125" hasComment="true"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="DECLARATION_STMT" minTextLength="0" hasSameDecType="false" hasComment="true"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="CONDITIONAL_STMT" type2="EXPRESSION_STMT" minTextLength="107" hasComment="false"/>
      <style_property newlines="1"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="DECLARATION_STMT" minTextLength="0" hasSameDecType="true" hasComment="false"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="DECLARATION_STMT" type2="CONDITIONAL_STMT" minTextLength="116" hasComment="false"/>
      <style_property newlines="2"/>
    </rule>
    <rule>
      <style_context type1="CONDITIONAL_STMT" type2="DECLARATION_STMT" minTextLength="0" hasComment="true"/>
      <style_property newlines="0"/>
    </rule>
    <rule>
      <style_context type1="EXPRESSION_STMT" type2="SINGLE_STMT" minTextLength="0" hasComment="false"/>
      <style_property newlines="0"/>
    </rule>
  </style>
  <style name="if_else_body_order"/>
  <style name="indention">
    <rule>
      <style_property indentionUnit="4" indentionType=" "/>
    </rule>
  </style>
  <style name="optional_brace">
    <rule>
      <style_context>
        <block_type>MULTI_BLOCK_STMT_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property use_brace="true"/>
    </rule>
  </style>
  <style name="brace_format">
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>MULTI</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="true"/>
    </rule>
    <rule>
      <style_context>
        <block_type>DEC_BODY</block_type>
        <body_type>SINGLE</body_type>
      </style_context>
      <style_property beforeLB="false" afterLB="true" beforeRB="false" afterRB="true"/>
    </rule>
  </style>
  <style name="declaration_layout"/>
  <style name="declaration_location">
    <rule>
      <style_property>
        <avgLineDis2firstUse>3.5</avgLineDis2firstUse>
        <location>BLOCK_START</location>
      </style_property>
    </rule>
  </style>
  <style name="structure_preference">
    <rule>
      <style_context id="17" category="Operator preferences"/>
      <style_property preferenceIndex="1"/>
    </rule>
    <rule>
      <style_context id="17" category="Operator preferences"/>
      <style_property preferenceIndex="0"/>
    </rule>
    <rule>
      <style_context id="25" category="Redundant code"/>
      <style_property preferenceIndex="0"/>
    </rule>
  </style>
  <style name="body_layout"/>
  <style name="lineWrapping">
    <rule>
      <style_context attr="CODE"/>
      <style_property variance="0.0" maxLen="0" maxLenBefore="0" succeedLoc="0">
        <breakLoc reg="," after="true"/>
        <breakLoc reg="[?:]" after="true"/>
        <breakLoc reg="[.]" after="false"/>
        <breakLoc reg="[&amp;]{2}" after="true"/>
        <breakLoc reg="[|]{2}" after="true"/>
        <breakLoc reg="[-+*/%&amp;|^]" after="true"/>
        <breakLoc reg="[=]{2,3}" after="true"/>
        <breakLoc reg="[-+*/%&amp;|^]=|&lt;&lt;=|&gt;&gt;=|&gt;&gt;&gt;=" after="true"/>
        <breakLoc reg="&lt;|&lt;=|&gt;|&gt;=|==|!=" after="true"/>
        <breakLoc reg="[(]" after="true"/>
      </style_property>
    </rule>
    <rule>
      <style_context attr="COMMENT"/>
      <style_property variance="0.0" maxLen="0" maxLenBefore="0" succeedLoc="0">
        <breakLoc reg=" +|[,.]" after="true"/>
      </style_property>
    </rule>
  </style>
</program_style>
