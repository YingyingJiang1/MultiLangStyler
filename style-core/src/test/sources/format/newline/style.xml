      <style_context nodeTypes="MUL, expression"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="BRANCH_STMT, RBRACE"/>
      <style_property newlines="1" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="modifierList, methodHead"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="LPAREN, expression"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="methodDeclarationList, RBRACE"/>
      <style_property newlines="1" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="qualifiedName, SEMI"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="expressionList, RPAREN"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="block, ELSE"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="SEMI, expression"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
  </style>
  <style name="modifier_order"/>
  <style name="structure_preference"/>
  <style name="body_layout">
    <rule>
      <style_context>
        <bodyType>STMT_BODY</bodyType>
        <bodySize>EMPTY</bodySize>
        <hasLeftNeighbour>true</hasLeftNeighbour>
        <hasRightNeighbour>false</hasRightNeighbour>
        <hasBrace>false</hasBrace>
      </style_context>
      <style_property beforeLB="0" afterRB="0"/>
    </rule>
    <rule>
      <style_context>
        <bodyType>STMT_BODY</bodyType>
        <bodySize>MULTI_STMTS</bodySize>
        <hasLeftNeighbour>true</hasLeftNeighbour>
        <hasRightNeighbour>false</hasRightNeighbour>
        <hasBrace>true</hasBrace>
      </style_context>
      <style_property beforeLB="0" afterRB="2"/>
    </rule>
    <rule>
      <style_context>
        <bodyType>STMT_BODY</bodyType>
        <bodySize>ONE_SINGLE_STMT</bodySize>
        <hasLeftNeighbour>true</hasLeftNeighbour>
        <hasRightNeighbour>false</hasRightNeighbour>
        <hasBrace>true</hasBrace>
      </style_context>
      <style_property beforeLB="0" afterRB="1"/>
    </rule>
    <rule>
      <style_context>
        <bodyType>STMT_BODY</bodyType>
        <bodySize>ONE_COMPOUND_STMT</bodySize>
        <hasLeftNeighbour>true</hasLeftNeighbour>
        <hasRightNeighbour>false</hasRightNeighbour>
        <hasBrace>true</hasBrace>
      </style_context>
      <style_property beforeLB="0" afterRB="1"/>
    </rule>
    <rule>
      <style_context>
        <bodyType>STMT_BODY</bodyType>
        <bodySize>ONE_SINGLE_STMT</bodySize>
        <hasLeftNeighbour>true</hasLeftNeighbour>
        <hasRightNeighbour>true</hasRightNeighbour>
        <hasBrace>true</hasBrace>
      </style_context>
      <style_property beforeLB="0" afterRB="0"/>
    </rule>
  </style>
  <style name="intra_newline"/>
</program_style>
