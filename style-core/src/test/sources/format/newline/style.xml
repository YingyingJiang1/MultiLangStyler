    <rule>
      <style_context nodeTypes="expression, LE"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="expression, RPAREN"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="LPAREN, RPAREN"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="expression, INC"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="modifierList, classHead"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
