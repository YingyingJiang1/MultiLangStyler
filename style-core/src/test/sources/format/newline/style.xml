<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="">
    <rule>
      <style_property hasNewline="true"/>
    </rule>
  </style>
  <style name="naming_format"/>
  <style name="if_else_body_order"/>
  <style name="indention">
    <rule>
      <style_property indentionUnit="1" indentionType="\t" indentEmptyLine="false" topHierarchyIndention="0"/>
    </rule>
  </style>
  <style name="optional_brace"/>
  <style name="expression_complexity"/>
  <style name="declaration_layout"/>
  <style name="declaration_location"/>
  <style name="space"/>
  <style name="newline">
    <rule>
      <style_context nodeTypes="methodHead, block" lengths="162.0"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="PRIVATE, STATIC" lengths="13.0"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="SINGLE_STMT, RBRACE" lengths="122.0"/>
      <style_property newlines="1" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="modifierList, methodHead" lengths="52.0"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="LBRACE, SINGLE_STMT" lengths="122.0"/>
      <style_property newlines="1" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="DOT, identifier" lengths="9.0"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="expression, DOT" lengths="9.0"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="DOT, methodCall" lengths="46.0"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="expression, DOT" lengths="61.0"/>
      <style_property newlines="1" breakIndex="1"/>
    </rule>
  </style>
  <style name="modifier_order"/>
  <style name="structure_preference"/>
  <style name="body_layout">
    <rule>
      <style_context>
        <bodyType>DEC_BODY</bodyType>
        <bodySize>ONE_SINGLE_STMT</bodySize>
        <hasLeftNeighbour>true</hasLeftNeighbour>
        <hasRightNeighbour>false</hasRightNeighbour>
        <hasBrace>true</hasBrace>
      </style_context>
      <style_property beforeLB="0" afterRB="0"/>
    </rule>
  </style>
  <style name="intra_newline">
    <rule>
      <style_context length="114.0"/>
      <style_property newlines="1" relativeIndention="			" lineLengthRatio="0.5"/>
    </rule>
  </style>
</program_style>
