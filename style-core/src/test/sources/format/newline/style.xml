<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="">
    <rule>
      <style_property hasNewline="true"/>
    </rule>
  </style>
  <style name="naming_format"/>
  <style name="if_else_body_order"/>
  <style name="indention">
    <rule>
      <style_property indentionUnit="1" indentionType="\t" indentEmptyLine="false" topHierarchyIndention="1"/>
    </rule>
  </style>
  <style name="optional_brace"/>
  <style name="expression_complexity"/>
  <style name="declaration_layout"/>
  <style name="declaration_location"/>
  <style name="space"/>
  <style name="newline">
    <rule>
      <style_context nodeTypes="identifier, arguments"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="RPAREN, block"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="typeType, variableDeclarators"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="LT, expression"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="parExpression, SINGLE_STMT"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="typeType, identifier"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="expression, MUL"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="expression, MOD"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="localVariableDeclarationStmt, BRANCH_STMT"/>
