      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="methodDeclaration, methodDeclaration"/>
      <style_property newlines="2" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="LPAREN, expressionList"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="localVariableDeclaration, SEMI"/>
