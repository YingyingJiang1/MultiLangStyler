    <rule>
      <style_context nodeTypes="localVariableDeclarationStmt, LOOP_STMT"/>
      <style_property newlines="2" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="FOR, LPAREN"/>
      <style_property newlines="0" breakIndex="1"/>
