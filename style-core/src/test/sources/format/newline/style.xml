      <style_context nodeTypes="LPAREN, forControl"/>
      <style_property newlines="0" breakIndex="1"/>
    </rule>
    <rule>
      <style_context nodeTypes="identifier, formalParameters"/>
      <style_property newlines="0" breakIndex="1"/>
