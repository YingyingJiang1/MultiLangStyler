<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format">
    <rule>
      <style_context nameType="LOCAL_VARIABLE"/>
      <style_property caseFormat="UPPER_CAMEL" startsWithUnderScore="false" maxLength="1"/>
    </rule>
  </style>
  <style name="newline"/>
  <style name="if_else_body_order"/>
  <style name="indention"/>
  <style name="optional_brace"/>
  <style name="modifier_order"/>
  <style name="structure_preference">
    <rule>
      <style_context id="1"/>
      <style_property preferenceIndex="4"/>
    </rule>
    <rule>
      <style_context id="12"/>
      <style_property preferenceIndex="1"/>
    </rule>
  </style>
  <style name="declaration_layout"/>
  <style name="inter_newline"/>
  <style name="body_layout"/>
  <style name="space"/>
  <style name="intra_newline"/>
</program_style>
