<?xml version="1.0" encoding="UTF-8"?>

<program_style>
  <style name="naming_format">
    <rule>
      <context number="1"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="2"/>
      <property statistic="{2=2}"/>
    </rule>
    <rule>
      <context number="3"/>
      <property statistic="{2=13}"/>
    </rule>
  </style>
  <style name="line_statement">
    <rule>
      <context number="1"/>
      <property statistic="{1=2}"/>
    </rule>
  </style>
  <style name="newline">
    <rule>
      <context number="1"/>
      <property statistic="{1=1}"/>
    </rule>
    <rule>
      <context number="2"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="3"/>
      <property statistic="{1=6}"/>
    </rule>
    <rule>
      <context number="4"/>
      <property statistic="{2=1}"/>
    </rule>
  </style>
  <style name="if_else_body_order"/>
  <style name="indention">
    <rule>
      <context number="1"/>
      <property statistic="{1=14}"/>
    </rule>
  </style>
  <style name="optional_brace"/>
  <style name="brace_format">
    <rule>
      <context number="1"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="2"/>
      <property statistic="{1=2}"/>
    </rule>
  </style>
  <style name="declaration_layout">
    <rule>
      <context number="1"/>
      <property statistic="{1=1}"/>
    </rule>
  </style>
  <style name="declaration_location">
    <rule>
      <context number="1"/>
      <property statistic="{1=2}"/>
    </rule>
  </style>
  <style name="structure_preference"/>
  <style name="body_layout"/>
  <style name="lineWrapping">
    <rule>
      <context number="1"/>
      <property statistic="{1=2}"/>
    </rule>
    <rule>
      <context number="2"/>
      <property statistic="{2=2}"/>
    </rule>
  </style>
</program_style>
